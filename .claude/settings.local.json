{
  "permissions": {
    "allow": [
      "WebFetch(domain:arxiv.org)",
      "Bash(where python:*)",
      "Bash(uv run python -c \":*)",
      "Bash(uv run:*)",
      "Bash(ruff check:*)",
      "Bash(ty check:*)",
      "Bash(find /d/Autoresearch-EvoX -type f \\\\\\(-name *.json -o -name *.toml -o -name *.cfg -o -name .env* \\\\\\))",
      "Bash(git init:*)",
      "Bash(git remote:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(grep -r \"lock\\\\|Lock\\\\|LOCK\\\\|atomic\\\\|mutex\\\\|thread\\\\|concurrent\" --include=*.py --include=*.md)",
      "Bash(find D:/Autoresearch-EvoX -name .claude -o -name settings* -o -name *lock* -type f)",
      "Bash(candidates\" for multi-GPU accuracy:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run evox/hooks/guard_json_edits.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "uv run evox/hooks/guard_destructive.py"
          },
          {
            "type": "command",
            "command": "uv run evox/hooks/validate_before_train.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run evox/hooks/validate_strategy.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run evox/hooks/auto_checkpoint.py"
          }
        ]
      }
    ]
  }
}
